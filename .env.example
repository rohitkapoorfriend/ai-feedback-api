# ----- Server -----
PORT=3000
NODE_ENV=development

# ----- MongoDB -----
# Local:  mongodb://localhost:27017/ai-feedback
# Docker: mongodb://mongo:27017/ai-feedback
MONGODB_URI=mongodb://localhost:27017/ai-feedback

# ----- OpenAI -----
# Get your key at: https://platform.openai.com/api-keys
# Leave blank if using MOCK_AI=true
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ----- Auth -----
# Use a long random string (min 32 chars) — never share this
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# ----- Rate Limiting -----
# 900000ms = 15 minutes window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ----- Mock Mode -----
# Set true to run WITHOUT an OpenAI key (uses keyword-based mock analysis)
# Perfect for local development and demos
MOCK_AI=true

# ----- Webhooks (Optional) -----
# After each analysis, results are POSTed to this URL
# Leave blank to disable
WEBHOOK_URL=
